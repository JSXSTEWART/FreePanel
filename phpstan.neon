# PHPStan configuration
#
# Level 0 is the minimum: catches hard errors like calls to undefined
# symbols, undefined variables, and similar. A baseline file records
# existing issues so the build stays green while preventing new
# regressions.
#
# To raise the level, delete phpstan-baseline.neon, raise `level`, and
# run `./vendor/bin/phpstan analyse --generate-baseline` to start over.

includes:
    - phpstan-baseline.neon

parameters:
    paths:
        - app
        - config
        - routes
    level: 0
    excludePaths:
        - bootstrap/cache/*
        - storage/*
        - vendor/*
